<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Triage_Status__c</fullName>
    <description>Where this ticket is in the BA agent triage pipeline, from intake through human approval.</description>
    <inlineHelpText>Tracks ticket triage: Not Started → Reviewing → Reviewed → Approved/Declined. Declined tickets return to Reviewing with reviewer notes for the BA agent to re-triage.</inlineHelpText>
    <label>Triage Status</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Not Started</fullName>
                <default>true</default>
                <label>Not Started</label>
            </value>
            <value>
                <fullName>Reviewing</fullName>
                <default>false</default>
                <label>Reviewing</label>
            </value>
            <value>
                <fullName>Reviewed</fullName>
                <default>false</default>
                <label>Reviewed</label>
            </value>
            <value>
                <fullName>Approved</fullName>
                <default>false</default>
                <label>Approved</label>
            </value>
            <value>
                <fullName>Declined</fullName>
                <default>false</default>
                <label>Declined</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
