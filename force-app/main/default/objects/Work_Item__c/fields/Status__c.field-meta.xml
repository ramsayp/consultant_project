<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Status__c</fullName>
    <description>The current stage of this work item in the delivery workflow. Drives which kanban column the card appears in.</description>
    <inlineHelpText>Update this to reflect where the item is in the process. The kanban board groups items by status automatically.</inlineHelpText>
    <label>Status</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value><fullName>Not Started</fullName><default>true</default><label>Not Started</label></value>
            <value><fullName>To Do</fullName><default>false</default><label>To Do</label></value>
            <value><fullName>In Progress</fullName><default>false</default><label>In Progress</label></value>
            <value><fullName>Blocked</fullName><default>false</default><label>Blocked</label></value>
            <value><fullName>Code Review</fullName><default>false</default><label>Code Review</label></value>
            <value><fullName>UAT</fullName><default>false</default><label>UAT</label></value>
            <value><fullName>Pipeline</fullName><default>false</default><label>Pipeline</label></value>
            <value><fullName>Released</fullName><default>false</default><label>Released</label></value>
            <value><fullName>Documented</fullName><default>false</default><label>Documented</label></value>
            <value><fullName>Done</fullName><default>false</default><label>Done</label></value>
            <value><fullName>Completed</fullName><default>false</default><label>Completed</label></value>
            <value><fullName>Cancelled</fullName><default>false</default><label>Cancelled</label></value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
