    <label>Target Type</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Story</fullName>
                <default>false</default>
                <label>Story</label>
            </value>
            <value>
                <fullName>Task</fullName>
                <default>false</default>
                <label>Task</label>
            </value>
            <value>
                <fullName>Bug</fullName>
                <default>false</default>
                <label>Bug</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
