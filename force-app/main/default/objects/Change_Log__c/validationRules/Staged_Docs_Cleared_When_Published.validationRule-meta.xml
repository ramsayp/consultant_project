<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Staged_Docs_Cleared_When_Published</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Status__c, &quot;Published&quot;), OR(NOT(ISBLANK(Staged_Technical_Body__c)), NOT(ISBLANK(Staged_User_Body__c))))</errorConditionFormula>
    <errorMessage>Staged documentation fields must be blank when the Change Log is Published.</errorMessage>
</ValidationRule>
