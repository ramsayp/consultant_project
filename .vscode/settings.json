{
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.sf": true,
    "**/.sfdx": true
  },
  "files.associations": {
    "**/__tests__/**/*.test.js": "javascript"
  },
  "xml.preferences.showSchemaDocumentationType": "none",
  "xml.validation.noGrammar": "ignore",
  "xml.downloadExternalResources.enabled": false
}
